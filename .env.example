# Core paths
CONTROL_TOWER_DATA_DIR=./data
CONTROL_TOWER_DB_PATH=./data/control_tower.db
CONTROL_TOWER_QUEUE_DIR=./data/queue
CONTROL_TOWER_WORKDIARY_DIR=..

# Server
HOST=127.0.0.1
PORT=4310
DEBUG=

# Telegram sync
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
TELEGRAM_2FA_PASSWORD=
CONTROL_TOWER_TELEGRAM_SESSION_PATH=./data/runtime/telegram_userbot.session

# Session wrapper behavior
CONTROL_TOWER_RESUME_MODE=resume

# Verdict pipeline
CONTROL_TOWER_VERDICT_COMMAND=
CONTROL_TOWER_VERDICT_TIMEOUT_SEC=90
CONTROL_TOWER_GEMINI_TIMEOUT_SEC=120
GEMINI_VERDICT_MODEL=gemini-2.5-flash

# Optional agent binary overrides
ANTIGRAVITY_BIN=antigravity
WINDSURF_BIN=windsurf
KILO_BIN=kilo
OPENCODE_BIN=opencode
