# 0-a-control environment example
# Copy this file to .env only for local use. Do not commit real secrets.

# Local server binding.
# Keep HOST as 127.0.0.1 for local-only operation.
HOST=127.0.0.1
PORT=4310

# Set DEBUG=1 only when HTTP request logs are needed.
# DEBUG=1

# Telegram sync is optional. Leave blank unless Telegram integration is used.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional Telegram session path override.
# Treat the session file as sensitive local data.
# CONTROL_TOWER_TELEGRAM_SESSION_PATH=data/runtime/telegram_userbot.session
