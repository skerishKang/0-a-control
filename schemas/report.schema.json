{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/skerishKang/0-a-control/schemas/report.schema.json",
  "title": "0-a-control Report Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "report"],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "report_id": {
      "type": "string"
    },
    "quest_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "agent_name": {
      "type": "string"
    },
    "correlation": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["quest_id", "quest_title", "completion_criteria", "work_summary"],
      "properties": {
        "quest_id": {
          "type": "string",
          "minLength": 1
        },
        "quest_title": {
          "type": "string",
          "minLength": 1
        },
        "completion_criteria": {
          "type": "string",
          "minLength": 1
        },
        "work_summary": {
          "type": "string",
          "minLength": 1
        },
        "remaining_work": {
          "type": "string"
        },
        "blocker": {
          "type": "string"
        },
        "self_assessment": {
          "type": "string",
          "enum": ["done", "partial", "hold", "pending", "unknown"]
        },
        "plan_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["bucket"],
            "properties": {
              "bucket": {
                "type": "string",
                "enum": ["today", "short_term", "long_term", "recurring", "dated"]
              },
              "plan_item_id": {
                "type": "string"
              }
            }
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
