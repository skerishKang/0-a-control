{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "0-a-control Report Contract",
  "type": "object",
  "required": ["schema_version", "report"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "report": {
      "type": "object",
      "required": [
        "quest_id",
        "quest_title",
        "completion_criteria",
        "work_summary"
      ],
      "additionalProperties": true,
      "properties": {
        "quest_id": { "type": "string", "minLength": 1 },
        "quest_title": { "type": "string", "minLength": 1 },
        "completion_criteria": {
          "type": ["string", "array"],
          "minLength": 1,
          "items": { "type": "string" }
        },
        "work_summary": { "type": "string", "minLength": 1 },
        "remaining_work": { "type": "string" },
        "blocker": { "type": "string" },
        "self_assessment": { "type": "string" },
        "plan_links": { "type": "array" },
        "attachments": { "type": "array" }
      }
    }
  }
}
