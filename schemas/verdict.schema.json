{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "0-a-control Verdict Contract",
  "type": "object",
  "required": ["schema_version", "report_ref", "verdict"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "report_ref": { "type": "string", "minLength": 1 },
    "verdict": {
      "type": "object",
      "required": ["status", "reason", "plan_impact"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["done", "partial", "hold"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "plan_impact": {
          "type": "object",
          "required": ["today", "short_term", "long_term", "recurring", "dated"],
          "additionalProperties": true,
          "properties": {
            "today": { "type": "array" },
            "short_term": { "type": "array" },
            "long_term": { "type": "array" },
            "recurring": { "type": "array" },
            "dated": { "type": "array" }
          }
        }
      }
    }
  }
}
