{
  "version": 1,
  "projects": [
    {
      "id": "example-project",
      "name": "Example Project",
      "path": "<LOCAL_WORKDIARY_PROJECT_PATH>",
      "enabled": true,
      "scan_rules": {
        "recent_days": 7,
        "max_recent_files": 10,
        "ignore_patterns": [
          "node_modules/",
          ".git/",
          "__pycache__/",
          "*.log",
          "*.pyc",
          ".venv/"
        ]
      },
      "entry_points": {
        "session_file": ".session/current.md",
        "todo_file": "TODO.md",
        "state_marker": ".workstate.json"
      }
    }
  ]
}
