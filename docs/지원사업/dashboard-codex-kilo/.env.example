# AI Provider Settings
# 4단계 분석 모드 구성 (quick / medium / deep / glm)

# ===== quick 모드 =====
# 빠르고 저렴한 모델, 대표 + fallback 체인
AI_QUICK_PROVIDER=groq
AI_QUICK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# fallback 모델 (쉼표로 구분, 같은 모드 내 순서대로 재시도)
AI_QUICK_FALLBACKS=openai/gpt-oss-20b

# ===== medium 모드 =====
# 중간 수준 분석, 대표 + fallback 체인
AI_MEDIUM_PROVIDER=groq
AI_MEDIUM_MODEL=qwen/qwen3-32b
AI_MEDIUM_FALLBACKS=meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b

# ===== deep 모드 =====
# 상세 분석, 대표 + fallback 체인
AI_DEEP_PROVIDER=groq
AI_DEEP_MODEL=openai/gpt-oss-120b
AI_DEEP_FALLBACKS=qwen/qwen3-32b,llama-3.3-70b-versatile

# ===== glm 모드 =====
# GLM 모델 (Modal 사용), 대표 + fallback
AI_GLM_PROVIDER=modal
AI_GLM_MODEL=zai-org/GLM-5-FP8
AI_GLM_FALLBACKS=

# ===== API 키 설정 =====

# Groq API (quick/medium/deep 모드용)
GROQ_API_KEY=

# Modal API (glm 모드용)
MODAL_API_KEY=

# NVIDIA NIM API (준비중)
NVIDIA_API_KEY=

# K-Startup API (공공데이터포털)
# https://www.data.go.kr/data/15125364/openapi.do
KSTARTUP_API_KEY=

# Bizinfo API (기업마당)
# https://www.bizinfo.go.kr/web/lay1/program/S1T175C174/apiList.do
BIZINFO_API_KEY=
